# Inference backend environment template
# Copy this file to .env and fill in values.

# ===== Cloudflare R2 Storage (required) =====
R2_BUCKET_NAME=your-r2-bucket
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_REGION=auto

# ===== Debug Settings (optional) =====
# Set to 'true' to save downloaded files to debug_downloads/ folder instead of temp
# This keeps PDFs and embeddings for inspection instead of auto-deleting them
DEBUG_SAVE_FILES=false
